model PlatformPaymentGateway {
  id          String             @id @default(uuid())
  slug        PaymentGatewaySlug @unique
  nameAr      String             @map("name_ar")
  nameEn      String             @map("name_en")
  isEnabled   Boolean            @default(false) @map("is_enabled")
  isTestMode  Boolean            @default(true) @map("is_test_mode")
  configJson  Json               @default("{}") @map("config_json")
  sortOrder   Int                @default(0) @map("sort_order")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@map("platform_payment_gateways")
}

model CompanyPaymentGateway {
  id          String             @id @default(uuid())
  companyId   String             @map("company_id")
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  slug        PaymentGatewaySlug
  isEnabled   Boolean            @default(false) @map("is_enabled")
  isTestMode  Boolean            @default(true) @map("is_test_mode")
  configJson  Json               @default("{}") @map("config_json")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@unique([companyId, slug])
  @@index([companyId])
  @@map("company_payment_gateways")
}

model BillingInvoice {
  id                String               @id @default(uuid())
  companyId         String               @map("company_id")
  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  number            String               @unique
  purpose           BillingPurpose
  description       String
  amount            Decimal
  currency          String               @default("OMR")
  status            BillingInvoiceStatus @default(PENDING)
  gatewaySlug       PaymentGatewaySlug?  @map("gateway_slug")
  externalPaymentId String?              @map("external_payment_id")
  checkoutUrl       String?              @map("checkout_url")
  metadataJson      Json?                @map("metadata_json")
  paidAt            DateTime?            @map("paid_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([status])
  @@map("billing_invoices")
}
