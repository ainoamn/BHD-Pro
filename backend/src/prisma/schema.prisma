generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== CORE TABLES ====================

model Company {
  id          String   @id @default(uuid())
  name        String
  crNumber    String?  @map("cr_number")
  vatNumber   String?  @map("vat_number")
  address     String?
  city        String?
  country     String   @default("OM")
  phone       String?
  email       String?
  website     String?
  logo        String?
  plan        Plan     @default(STARTER)
  planExpiry  DateTime? @map("plan_expiry")
  isActive    Boolean  @default(true) @map("is_active")
  timezone    String   @default("Asia/Muscat")
  currency    String   @default("OMR")
  language    String   @default("ar")
  fiscalYearStart Int @default(1) @map("fiscal_year_start")

  zatcaConfig Json?   @map("ota_config")
  ftaConfig   Json?   @map("tax_config")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  users       User[]
  contacts    Contact[]
  products    Product[]
  invoices    Invoice[]
  journals    Journal[]
  accounts    Account[]
  warehouses  Warehouse[]
  paymentGateways CompanyPaymentGateway[]
  billingInvoices BillingInvoice[]
  branches      Branch[]
  costCenters   CostCenter[]
  projects      Project[]
  employees     Employee[]
  payrollRuns   PayrollRun[]
  fixedAssets   FixedAsset[]
  bankAccounts  BankAccount[]
  bankStatementLines BankStatementLine[]
  purchaseOrders PurchaseOrder[]
  scheduledInvoices ScheduledInvoice[]

  @@index([vatNumber])
  @@index([crNumber])
  @@index([isActive])
  @@map("companies")
}

model User {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  email       String   @unique
  password    String
  avatar      String?
  role        UserRole @default(ACCOUNTANT)
  permissions Json?

  isActive    Boolean  @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")
  loginAttempts Int    @default(0) @map("login_attempts")
  lockedUntil DateTime? @map("locked_until")
  twoFactorSecret String? @map("2fa_secret")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdInvoices Invoice[] @relation("CreatedBy")
  createdJournals Journal[] @relation("CreatedBy")
  purchaseOrdersCreated PurchaseOrder[] @relation("PurchaseOrdersCreated")
  scheduledInvoicesCreated ScheduledInvoice[] @relation("ScheduledInvoicesCreated")
  auditLogs   AuditLog[]
  sessions    Session[]

  @@index([companyId])
  @@index([email])
  @@index([role])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

// ==================== ACCOUNTING TABLES ====================

model Account {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code        String
  name        String
  nameEn      String?  @map("name_en")
  type        AccountType
  category    AccountCategory
  parentId    String?  @map("parent_id")
  parent      Account? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[] @relation("AccountHierarchy")

  openingBalance Decimal @default(0) @map("opening_balance")
  currentBalance Decimal @default(0) @map("current_balance")

  isActive    Boolean  @default(true) @map("is_active")
  isBank      Boolean  @default(false) @map("is_bank")
  bankAccount String?  @map("bank_account")
  bankName    String?  @map("bank_name")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  journalLines JournalLine[]
  fixedAssets  FixedAsset[]
  bankAccounts BankAccount[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([type])
  @@index([category])
  @@map("accounts")
}

model Journal {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  number      String
  date        DateTime
  description String?
  reference   String?

  totalDebit  Decimal  @map("total_debit")
  totalCredit Decimal  @map("total_credit")
  isBalanced  Boolean  @default(false) @map("is_balanced")

  createdById String   @map("created_by_id")
  createdBy   User     @relation("CreatedBy", fields: [createdById], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  lines       JournalLine[]
  invoicePosting Invoice? @relation("InvoiceGlJournal")
  paymentPosting Payment? @relation("PaymentGlJournal")

  @@index([companyId])
  @@index([date])
  @@index([number])
  @@map("journals")
}

model JournalLine {
  id          String   @id @default(uuid())
  journalId   String   @map("journal_id")
  journal     Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)

  accountId   String   @map("account_id")
  account     Account  @relation(fields: [accountId], references: [id])

  description String?
  debit       Decimal  @default(0)
  credit      Decimal  @default(0)
  costCenterId String? @map("cost_center_id")
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])
  projectId    String? @map("project_id")
  project      Project? @relation(fields: [projectId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([journalId])
  @@index([accountId])
  @@index([costCenterId])
  @@index([projectId])
  @@map("journal_lines")
}

model Branch {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code         String
  name         String
  nameEn       String?  @map("name_en")
  address      String?
  city         String?
  phone        String?
  isHeadOffice Boolean  @default(false) @map("is_head_office")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  employees    Employee[]
  projects     Project[]
  costCenters  CostCenter[]
  fixedAssets  FixedAsset[]
  bankAccounts BankAccount[]
  payrollRuns  PayrollRun[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("branches")
}

model CostCenter {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId    String?  @map("branch_id")
  branch      Branch?  @relation(fields: [branchId], references: [id])
  code        String
  name        String
  nameEn      String?  @map("name_en")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  journalLines JournalLine[]
  projects     Project[]
  invoices     Invoice[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("cost_centers")
}

model Project {
  id            String        @id @default(uuid())
  companyId     String        @map("company_id")
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId      String?       @map("branch_id")
  branch        Branch?       @relation(fields: [branchId], references: [id])
  costCenterId  String?       @map("cost_center_id")
  costCenter    CostCenter?   @relation(fields: [costCenterId], references: [id])
  code          String
  name          String
  nameEn        String?       @map("name_en")
  description   String?
  startDate     DateTime?     @map("start_date")
  endDate       DateTime?     @map("end_date")
  budget        Decimal       @default(0)
  status        ProjectStatus @default(ACTIVE)
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  journalLines  JournalLine[]
  invoices      Invoice[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("projects")
}

model Employee {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId       String?  @map("branch_id")
  branch         Branch?  @relation(fields: [branchId], references: [id])
  employeeNumber String   @map("employee_number")
  name           String
  nameEn         String?  @map("name_en")
  email          String?
  phone          String?
  jobTitle       String?  @map("job_title")
  department     String?
  baseSalary     Decimal  @default(0) @map("base_salary")
  hireDate       DateTime? @map("hire_date")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  payrollLines   PayrollLine[]

  @@unique([companyId, employeeNumber])
  @@index([companyId])
  @@map("employees")
}

model PayrollRun {
  id          String        @id @default(uuid())
  companyId   String        @map("company_id")
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId    String?       @map("branch_id")
  branch      Branch?       @relation(fields: [branchId], references: [id])
  number      String
  periodMonth Int           @map("period_month")
  periodYear  Int           @map("period_year")
  date        DateTime      @default(now())
  status      PayrollStatus @default(DRAFT)
  totalNet    Decimal       @default(0) @map("total_net")
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  lines       PayrollLine[]

  @@unique([companyId, number])
  @@index([companyId])
  @@map("payroll_runs")
}

model PayrollLine {
  id           String     @id @default(uuid())
  payrollRunId String     @map("payroll_run_id")
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId   String     @map("employee_id")
  employee     Employee   @relation(fields: [employeeId], references: [id])
  baseSalary   Decimal    @default(0) @map("base_salary")
  allowances   Decimal    @default(0)
  deductions   Decimal    @default(0)
  netSalary    Decimal    @default(0) @map("net_salary")

  @@index([payrollRunId])
  @@index([employeeId])
  @@map("payroll_lines")
}

model FixedAsset {
  id                String        @id @default(uuid())
  companyId         String        @map("company_id")
  company           Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId          String?       @map("branch_id")
  branch            Branch?       @relation(fields: [branchId], references: [id])
  accountId         String?       @map("account_id")
  account           Account?      @relation(fields: [accountId], references: [id])
  code              String
  name              String
  nameEn            String?       @map("name_en")
  category          AssetCategory @default(OTHER)
  purchaseDate      DateTime?     @map("purchase_date")
  purchaseCost      Decimal       @default(0) @map("purchase_cost")
  currentValue      Decimal       @default(0) @map("current_value")
  depreciationRate  Decimal       @default(0) @map("depreciation_rate")
  location          String?
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@unique([companyId, code])
  @@index([companyId])
  @@map("fixed_assets")
}

model BankAccount {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId       String?  @map("branch_id")
  branch         Branch?  @relation(fields: [branchId], references: [id])
  accountId      String?  @map("account_id")
  glAccount      Account? @relation(fields: [accountId], references: [id])
  name           String
  bankName       String   @map("bank_name")
  accountNumber  String   @map("account_number")
  iban           String?
  currency       String   @default("OMR")
  openingBalance Decimal  @default(0) @map("opening_balance")
  currentBalance Decimal  @default(0) @map("current_balance")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  statementLines BankStatementLine[]

  @@index([companyId])
  @@map("bank_accounts")
}

model BankStatementLine {
  id            String      @id @default(uuid())
  companyId     String      @map("company_id")
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankAccountId String      @map("bank_account_id")
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  date          DateTime
  description   String
  reference     String?
  /// Positive = deposit / credit; negative = withdrawal / debit
  amount        Decimal
  isReconciled  Boolean     @default(false) @map("is_reconciled")
  reconciledAt  DateTime?   @map("reconciled_at")

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([bankAccountId])
  @@index([date])
  @@map("bank_statement_lines")
}

// ==================== INVOICE TABLES ====================

model Invoice {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  number      String
  type        InvoiceType @default(SALES)

  contactId   String   @map("contact_id")
  contact     Contact  @relation(fields: [contactId], references: [id])

  date        DateTime
  dueDate     DateTime @map("due_date")

  subtotal    Decimal 
  discount    Decimal  @default(0)
  taxRate     Decimal  @default(5) @map("tax_rate")
  taxAmount   Decimal  @map("tax_amount")
  total       Decimal 
  paidAmount  Decimal  @default(0) @map("paid_amount")

  status      InvoiceStatus @default(DRAFT)
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")

  vatUuid     String?  @map("vat_uuid") @unique
  xmlContent  String?  @map("xml_content")
  qrCode      String?  @map("qr_code")
  hash        String?
  signedXml   String?  @map("signed_xml")
  clearedAt   DateTime? @map("cleared_at")

  notes       String?
  terms       String?

  costCenterId String?     @map("cost_center_id")
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])
  projectId    String?     @map("project_id")
  project      Project?    @relation(fields: [projectId], references: [id])

  glJournalId String?  @unique @map("gl_journal_id")
  glJournal   Journal? @relation("InvoiceGlJournal", fields: [glJournalId], references: [id])

  createdById String   @map("created_by_id")
  createdBy   User     @relation("CreatedBy", fields: [createdById], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items       InvoiceItem[]
  payments    Payment[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@index([date])
  @@index([costCenterId])
  @@index([projectId])
  @@index([vatUuid])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId   String?  @map("product_id")
  product     Product? @relation(fields: [productId], references: [id])

  description String
  quantity    Decimal 
  unitPrice   Decimal  @map("unit_price")
  discount    Decimal  @default(0)
  taxRate     Decimal  @default(5) @map("tax_rate")
  taxAmount   Decimal  @map("tax_amount")
  total       Decimal 

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([invoiceId])
  @@index([productId])
  @@map("invoice_items")
}

model Payment {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount      Decimal 
  method      PaymentMethod
  reference   String?
  date        DateTime
  notes       String?

  glJournalId String?  @unique @map("gl_journal_id")
  glJournal   Journal? @relation("PaymentGlJournal", fields: [glJournalId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([invoiceId])
  @@map("payments")
}

model PurchaseOrder {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  number      String
  contactId   String   @map("contact_id")
  contact     Contact  @relation(fields: [contactId], references: [id])

  date        DateTime
  expectedDate DateTime? @map("expected_date")

  subtotal    Decimal
  discount    Decimal  @default(0)
  taxRate     Decimal  @default(5) @map("tax_rate")
  taxAmount   Decimal  @map("tax_amount")
  total       Decimal

  status      PurchaseOrderStatus @default(DRAFT)
  notes       String?

  createdById String   @map("created_by_id")
  createdBy   User     @relation("PurchaseOrdersCreated", fields: [createdById], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items       PurchaseOrderItem[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([contactId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  order       PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId   String?  @map("product_id")
  product     Product? @relation(fields: [productId], references: [id])

  description String
  quantity    Decimal
  unitPrice   Decimal  @map("unit_price")
  discount    Decimal  @default(0)
  taxRate     Decimal  @default(5) @map("tax_rate")
  taxAmount   Decimal  @map("tax_amount")
  total       Decimal

  @@index([orderId])
  @@map("purchase_order_items")
}

model ScheduledInvoice {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  contactId   String   @map("contact_id")
  contact     Contact  @relation(fields: [contactId], references: [id])

  frequency   ScheduleFrequency @default(MONTHLY)
  nextDate    DateTime @map("next_date")
  lastGeneratedAt DateTime? @map("last_generated_at")
  isActive    Boolean  @default(true) @map("is_active")

  subtotal    Decimal
  discount    Decimal  @default(0)
  taxRate     Decimal  @default(5) @map("tax_rate")
  taxAmount   Decimal  @map("tax_amount")
  total       Decimal
  notes       String?

  createdById String   @map("created_by_id")
  createdBy   User     @relation("ScheduledInvoicesCreated", fields: [createdById], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items       ScheduledInvoiceItem[]

  @@index([companyId])
  @@index([contactId])
  @@index([nextDate])
  @@map("scheduled_invoices")
}

model ScheduledInvoiceItem {
  id          String   @id @default(uuid())
  scheduleId  String   @map("schedule_id")
  schedule    ScheduledInvoice @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  productId   String?  @map("product_id")
  product     Product? @relation(fields: [productId], references: [id])

  description String
  quantity    Decimal
  unitPrice   Decimal  @map("unit_price")
  discount    Decimal  @default(0)
  taxRate     Decimal  @default(5) @map("tax_rate")
  taxAmount   Decimal  @map("tax_amount")
  total       Decimal

  @@index([scheduleId])
  @@map("scheduled_invoice_items")
}

// ==================== INVENTORY TABLES ====================

model Product {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  sku         String   @unique
  name        String
  nameEn      String?  @map("name_en")
  description String?
  category    String
  barcode     String?  @unique

  costPrice   Decimal  @map("cost_price")
  salePrice   Decimal  @map("sale_price")

  quantity    Decimal  @default(0)
  minQuantity Decimal  @default(5) @map("min_quantity")
  maxQuantity Decimal? @map("max_quantity")
  reorderPoint Decimal @default(10) @map("reorder_point")

  unit        String   @default("piece")
  warehouseId String?  @map("warehouse_id")
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  isActive    Boolean  @default(true) @map("is_active")
  isTracked   Boolean  @default(true) @map("is_tracked")

  images      String[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  invoiceItems InvoiceItem[]
  purchaseOrderItems PurchaseOrderItem[]
  scheduledInvoiceItems ScheduledInvoiceItem[]
  stockMovements StockMovement[]

  @@index([companyId])
  @@index([sku])
  @@index([category])
  @@map("products")
}

model Warehouse {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  code        String
  address     String?
  isActive    Boolean  @default(true) @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at")

  products    Product[]
  stockMovements StockMovement[]

  @@unique([companyId, code])
  @@map("warehouses")
}

model StockMovement {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String   @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  type        MovementType
  quantity    Decimal 
  unitCost    Decimal  @map("unit_cost")
  reference   String?
  notes       String?

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([warehouseId])
  @@map("stock_movements")
}

// ==================== CONTACT TABLES ====================

model Contact {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  type        ContactType
  name        String
  nameEn      String?  @map("name_en")

  taxId       String?  @map("tax_id")
  crNumber    String?  @map("cr_number")

  email       String?
  phone       String?
  phone2      String?
  fax         String?

  address     String?
  city        String?
  country     String   @default("OM")
  zipCode     String?  @map("zip_code")

  openingBalance Decimal @default(0) @map("opening_balance")
  currentBalance Decimal @default(0) @map("current_balance")
  creditLimit Decimal? @map("credit_limit")
  paymentTerms Int?     @map("payment_terms")

  website     String?
  notes       String?
  isActive    Boolean  @default(true) @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  invoices    Invoice[]
  purchaseOrders PurchaseOrder[]
  scheduledInvoices ScheduledInvoice[]

  @@index([companyId])
  @@index([type])
  @@index([taxId])
  @@map("contacts")
}

// ==================== AUDIT & LOGS ====================

model AuditLog {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])

  action      String
  entity      String
  entityId    String?  @map("entity_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([companyId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

