# Qootk Pro - Environment Variables

# Database
DATABASE_URL=postgresql://qootk:qootk_secret@localhost:5432/qootk_pro?schema=public

# JWT
JWT_SECRET=qootk-dev-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=qootk-dev-refresh-secret-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Backend
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001

# Platform payment gateways (subscription billing)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
THAWANI_PUBLISHABLE_KEY=
THAWANI_SECRET_KEY=
THAWANI_WEBHOOK_SECRET=
THAWANI_BASE_URL=https://uatcheckout.thawani.om/api/v1
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
