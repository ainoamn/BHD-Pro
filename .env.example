# BHD Pro - Environment Variables
# Copy to backend/.env and frontend/.env.local as needed.
# NEVER commit real secrets.

# Set to production when deploying — enforces strong JWT / payment secret checks
NODE_ENV=development

# Database
DATABASE_URL=postgresql://qootk:CHANGE_ME_STRONG_DB_PASSWORD@localhost:5432/qootk_pro?schema=public
# Same as DATABASE_URL locally; on Neon use the non-pooled connection string
DIRECT_URL=postgresql://qootk:CHANGE_ME_STRONG_DB_PASSWORD@localhost:5432/qootk_pro?schema=public

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_OPENSSL_RAND_BASE64_48
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Encrypt payment gateway secrets at rest (AES-256-GCM) — openssl rand -base64 48
PAYMENT_SECRETS_KEY=REPLACE_WITH_OPENSSL_RAND_BASE64_48

# Comma-separated emails allowed to manage platform payment gateways
PLATFORM_ADMIN_EMAILS=you@yourdomain.com

# Backend
PORT=3001
# Production MUST be your HTTPS frontend origin (not localhost)
# Comma-separated if you use both apex and www
CORS_ORIGIN=http://localhost:3000

# Google Sign-In (same Client ID on backend + frontend)
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Frontend — use same-origin proxy so httpOnly cookies work
NEXT_PUBLIC_API_URL=/backend-api
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001
# Used by Next.js rewrite in next.config.js
BACKEND_URL=http://localhost:3001

# Cookie SameSite: lax (same-site / Next proxy) | none (API on another domain — requires HTTPS)
# COOKIE_SAME_SITE=lax

# Platform payment gateways (subscription billing)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
THAWANI_PUBLISHABLE_KEY=
THAWANI_SECRET_KEY=
THAWANI_WEBHOOK_SECRET=
THAWANI_BASE_URL=https://uatcheckout.thawani.om/api/v1
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
