# BHD Pro - Environment Variables
# Copy to backend/.env and frontend/.env.local as needed.
# NEVER commit real secrets.

# Set to production when deploying — enforces strong JWT / payment secret checks
NODE_ENV=development

# Database
DATABASE_URL=postgresql://qootk:CHANGE_ME_STRONG_DB_PASSWORD@localhost:5432/qootk_pro?schema=public

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_OPENSSL_RAND_BASE64_48
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Encrypt payment gateway secrets at rest (AES-256-GCM) — openssl rand -base64 48
PAYMENT_SECRETS_KEY=REPLACE_WITH_OPENSSL_RAND_BASE64_48

# Comma-separated emails allowed to manage platform payment gateways
PLATFORM_ADMIN_EMAILS=you@yourdomain.com

# Backend
PORT=3001
# Production MUST be your HTTPS frontend origin (not localhost)
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001

# Platform payment gateways (subscription billing)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
THAWANI_PUBLISHABLE_KEY=
THAWANI_SECRET_KEY=
THAWANI_WEBHOOK_SECRET=
THAWANI_BASE_URL=https://uatcheckout.thawani.om/api/v1
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
