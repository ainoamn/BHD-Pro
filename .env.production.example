# Production template for https://hisaby.pro
# Copy to the server as backend/.env (and set frontend env / compose env).
# NEVER commit real secrets.

NODE_ENV=production

# Used by docker-compose.prod.yml
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# PostgreSQL — change password before go-live
# On Neon: DATABASE_URL = pooled (-pooler), DIRECT_URL = non-pooled (no -pooler)
DATABASE_URL=postgresql://hisaby:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/hisaby_pro?schema=public
DIRECT_URL=postgresql://hisaby:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/hisaby_pro?schema=public

# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_OPENSSL_RAND_BASE64_48
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

PAYMENT_SECRETS_KEY=REPLACE_WITH_OPENSSL_RAND_BASE64_48

# Your admin email(s) for platform payment gateways
PLATFORM_ADMIN_EMAILS=admin@hisaby.pro

PORT=3001

# Public site — include www if users open https://www.hisaby.pro
CORS_ORIGIN=https://hisaby.pro,https://www.hisaby.pro,https://bhd-pro.vercel.app
FRONTEND_URL=https://www.hisaby.pro
# Same origin via Nginx proxy (recommended)
API_PUBLIC_URL=https://hisaby.pro
BACKEND_URL=http://backend:3001

# Frontend (Next)
NEXT_PUBLIC_API_URL=/backend-api
NEXT_PUBLIC_APP_URL=https://www.hisaby.pro

# Google Sign-In — create OAuth Client ID in Google Cloud Console
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

COOKIE_SAME_SITE=lax

# Payment gateways — fill when ready (keep test mode first)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
THAWANI_PUBLISHABLE_KEY=
THAWANI_SECRET_KEY=
THAWANI_WEBHOOK_SECRET=
THAWANI_BASE_URL=https://uatcheckout.thawani.om/api/v1
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
